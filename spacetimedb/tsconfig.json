{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",

    "target": "ESNext",
    "lib": ["ES2021"],
    "module": "ESNext",
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["./src/**/*", "../shared/**/*"],
  "exclude": ["../shared/**/*.test.ts"]
}
