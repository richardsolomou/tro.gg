{
  "name": "tro.gg",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:module": "tsc -p spacetimedb/tsconfig.json --noEmit",
    "test": "TSX_TSCONFIG_PATH=test/tsconfig.json node --import tsx --test \"shared/*.test.ts\" \"src/*.test.ts\" \"test/*.test.ts\"",
    "test:e2e": "playwright test",
    "sprite-art": "tsx tools/gen-sprite-art.ts",
    "item-art": "tsx tools/gen-item-art.ts",
    "sprites": "tsx tools/gen-spritesheet.ts",
    "art": "pnpm run sprite-art && pnpm run item-art && pnpm run sprites",
    "art:check": "pnpm run art && pnpm run typecheck && pnpm run test",
    "art:preview": "tsx tools/preview-sprites.ts"
  },
  "dependencies": {
    "oidc-client-ts": "^3.5.0",
    "phaser": "^4.2.0",
    "posthog-js": "^1.391.2",
    "spacetimedb": "2.6.*",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/three": "^0.185.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
