# Copy to server/.env. Defaults match docker-compose.yml, so the server persists
# against the local Postgres + Valkey out of the box. Valkey speaks the Redis
# protocol — hence REDIS_URL and the redis:// scheme.
PORT=2567
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://trogg:trogg@localhost:5432/trogg
REDIS_URL=redis://localhost:6379
# A stable key signing guest credentials. Any non-empty string works in dev;
# changing it invalidates existing guest tokens. Use a real random value in prod.
AUTH_SECRET=dev-secret-change-me
