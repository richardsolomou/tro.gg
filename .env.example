# Copy to .env. The host/database default to a local `spacetime start` instance
# and the `trogg` module. PostHog is a no-op when the key is unset, so it's
# optional for a local loop.
VITE_SPACETIMEDB_HOST=ws://localhost:3000
VITE_SPACETIMEDB_DB_NAME=trogg
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# SpacetimeAuth (account sign-in). Unset = guest-only, no account UI (fine for a
# local loop). The client id comes from your SpacetimeAuth project's client; it's
# a public client (PKCE), so there is no secret here. Redirect URI defaults to
# <origin>/play — set it only to override.
VITE_SPACETIMEAUTH_CLIENT_ID=
VITE_SPACETIMEAUTH_REDIRECT_URI=
